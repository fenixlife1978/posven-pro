rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // FUNCIONES AUXILIARES
    // ============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Simplificamos isAdmin para evitar recursión innecesaria durante el login
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'administrador';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ============================================================
    // REGLAS PARA USUARIOS
    // ============================================================
    match /users/{userId} {
      // Un usuario autenticado puede leer perfiles (necesario para validación de roles)
      allow read: if isAuthenticated();
      // Un usuario puede crear su propio perfil o el admin puede editar cualquiera
      allow write: if isOwner(userId) || isAdmin();
    }

    // ============================================================
    // REGLAS PARA POS_SYSTEM_DATA (CONFIGURACIÓN)
    // ============================================================
    match /pos_system_data/{document} {
      // Lectura pública del estado para permitir el flujo de "Primer Uso" y Tasa BCV
      allow read: if true;
      
      // Permitimos escritura si el usuario está autenticado. 
      // El primer admin se autentica vía Auth antes de escribir este doc.
      allow write: if isAuthenticated();
      
      match /{subcollection}/{subdocument} {
        allow read, write: if isAuthenticated();
      }
    }

    // ============================================================
    // REGLAS PARA OTRAS COLECCIONES
    // ============================================================
    match /products/{document} { allow read, write: if isAuthenticated(); }
    match /orders/{document} { allow read, write: if isAuthenticated(); }
    match /sales/{document} { allow read, write: if isAuthenticated(); }
    match /customers/{document} { allow read, write: if isAuthenticated(); }
    match /suppliers/{document} { allow read, write: if isAuthenticated(); }
    match /movimientos/{document} { allow read, write: if isAuthenticated(); }
    match /libro_diario/{document} { allow read, write: if isAuthenticated(); }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}