rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // FUNCIONES DE SOPORTE
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().rol == 'administrador';
    }

    // EL ESTADO DEL SISTEMA (Público para lectura inicial)
    match /pos_system_data/{docId} {
      allow read: if true;
      allow write: if isAdmin() || (docId == 'state' && request.resource.data.isInitialized == true);
    }

    // PERFILES DE USUARIO
    match /users/{userId} {
      // Un usuario puede leer su propio perfil. Un admin puede leer todos.
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // El administrador tiene control total. 
      // El usuario puede crear su perfil inicial si el UID coincide.
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // REGLA MAESTRA PARA OPERACIONES (Productos, Ventas, CXC, CXP, etc.)
    match /{collectionName}/{docId} {
      // El administrador siempre tiene acceso
      allow read, write: if isAdmin();
      
      // Los cajeros tienen acceso si NO están bloqueados
      allow read, write: if isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().rol == 'cajero' && 
        getUserData().accesoBloqueado == false;
    }
  }
}